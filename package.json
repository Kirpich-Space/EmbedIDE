{
  "name": "embed-ide",
  "version": "0.2.0",
  "private": false,
  "description": "EmbedIDE — Modern Engineering IDE for Embedded Development",
  "author": {
    "name": "EmbedIDE",
    "url": "https://github.com/anomalyco/EmbedIDE"
  },
  "license": "MIT",
  "homepage": "https://github.com/anomalyco/EmbedIDE",
  "repository": {
    "type": "git",
    "url": "https://github.com/anomalyco/EmbedIDE.git"
  },
  "bugs": {
    "url": "https://github.com/anomalyco/EmbedIDE/issues"
  },
  "keywords": [
    "embedded",
    "ide",
    "stm32",
    "arm",
    "cortex-m",
    "rust",
    "c",
    "cpp",
    "electronics",
    "firmware"
  ],
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"sleep 3 && VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "vite build",
    "start": "electron .",
    "launch": "vite build && electron .",
    "pack": "vite build && electron-builder --dir",
    "dist:linux": "vite build && electron-builder --linux",
    "dist:win": "vite build && electron-builder --win",
    "dist:mac": "vite build && electron-builder --mac",
    "dist:all": "vite build && electron-builder --linux --win --mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.embedide.app",
    "productName": "EmbedIDE",
    "copyright": "Copyright © 2024 EmbedIDE",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icons",
        "to": "icons"
      }
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "deb",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "Development",
      "icon": "build/icons/512.png",
      "artifactName": "${name}-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icons/icon.ico",
      "artifactName": "${name}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EmbedIDE"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "build/icons/512.png",
      "category": "public.app-category.developer-tools",
      "artifactName": "${name}-${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.6",
    "codemirror": "^6.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
